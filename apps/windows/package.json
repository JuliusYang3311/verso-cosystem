{
  "name": "verso-desktop-windows",
  "version": "1.0.0",
  "description": "Verso Desktop App (Windows)",
  "author": "Julius Yang <yangzhenyu528@gmail.com>",
  "main": "main.js",
  "scripts": {
    "prepare:build": "bash scripts/prepare-build.sh",
    "build:win": "bash scripts/prepare-build.sh && npx electron-builder --win --x64",
    "build:win:dir": "bash scripts/prepare-build.sh && npx electron-builder --win --dir"
  },
  "build": {
    "appId": "com.verso.desktop",
    "productName": "Verso",
    "icon": "assets/icon.ico",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": false,
      "license": "../../LICENSE.txt"
    },
    "asar": true,
    "compression": "normal",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "auth/**/*",
      "gateway/**/*",
      "lib/**/*"
    ],
    "extraResources": [
      {
        "from": "../../LICENSE.txt",
        "to": "LICENSE.txt"
      },
      {
        "from": "../../node.exe",
        "to": "gateway/node.exe"
      },
      {
        "from": "../../dist",
        "to": "gateway/dist"
      },
      {
        "from": "../../extensions",
        "to": "gateway/extensions"
      },
      {
        "from": "../../skills",
        "to": "gateway/skills"
      },
      {
        "from": "../../assets",
        "to": "gateway/assets"
      },
      {
        "from": "../../build-node-modules-win",
        "to": "gateway/node_modules"
      },
      {
        "from": "../../package.json",
        "to": "gateway/package.json"
      },
      {
        "from": "../../docs/reference/templates",
        "to": "gateway/docs/reference/templates"
      }
    ],
    "asarUnpack": [
      "gateway/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.52.9",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8"
  }
}
